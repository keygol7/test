APP_NAME="News Situation API"
ENVIRONMENT="development"
DATABASE_URL="postgresql+psycopg://postgres:postgres@localhost:5432/news_dashboard"
CORS_ORIGINS_CSV=""
JWT_SECRET_KEY="your-secret-key-here"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=60
ADMIN_EMAIL=""

# LLM Categorization (MCP)
LLM_PROVIDER="anthropic"
LLM_API_KEY=""
LLM_MODEL=""
CATEGORIZER_ENABLED=false
CATEGORIZER_INTERVAL_MINUTES=5
CATEGORIZER_BATCH_SIZE=50
CATEGORIZER_RELEVANCE_THRESHOLD=0.3
CATEGORIZER_UNCATEGORIZED_SINCE_HOURS=0
CATEGORIZER_DISCOVERY_LIMIT=1000
CATEGORIZER_DISCOVERY_SINCE_HOURS=336
CATEGORIZER_BACKFILL_ENABLED=true
CATEGORIZER_BACKFILL_CHUNK_SIZE=500
CATEGORIZER_BACKFILL_WRITE_BATCH_SIZE=50
CATEGORIZER_BACKFILL_MAX_SITUATIONS_PER_CYCLE=20
