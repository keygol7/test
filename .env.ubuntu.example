STACK_NAME=newsdash

PUBLIC_HOST=app.example.com
CADDY_HTTP_PORT=8080

POSTGRES_DB=news_dashboard
POSTGRES_USER=news_user
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DATA_PATH=/opt/news-dashboard/postgres

# Needed for cloudflared service.
CLOUDFLARE_TUNNEL_TOKEN=replace-with-your-tunnel-token

# Build/push custom images and set names here if using a registry.
BACKEND_IMAGE=news-dashboard-backend:latest
FRONTEND_IMAGE=news-dashboard-frontend:latest
AUTOSCALER_IMAGE=news-dashboard-autoscaler:latest

# Keep empty when frontend and backend are same origin through Caddy.
CORS_ORIGINS_CSV=

# Baseline replica settings.
BACKEND_MIN_REPLICAS=2
BACKEND_MAX_REPLICAS=8
FRONTEND_REPLICAS=2

# Autoscaler tuning.
AUTOSCALE_INTERVAL_SEC=30
AUTOSCALE_COOLDOWN_SEC=120
AUTOSCALE_STEP=1
AUTOSCALE_UP_CPU=75
AUTOSCALE_DOWN_CPU=25
AUTOSCALE_WINDOW_SIZE=3
